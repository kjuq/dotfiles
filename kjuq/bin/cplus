#!/usr/bin/env bash

output="/tmp/cplus_output"

debug_opts="-D_GLIBCXX_DEBUG -D_GLIBCXX_DEBUG_PEDANTIC"

while getopts "t" opt; do
	case "$opt" in
	t) # traceback
		debug_opts=""
		shift 1
		;;
	esac
done

# echo "$@"
g++ -std=c++23 -Wall -Wextra -g -o "$output" "$@" && "$output"
command rm "$output"
