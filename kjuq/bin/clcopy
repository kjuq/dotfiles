#!/usr/bin/env bash

set -eu

# `mkdir -p ~/.local/bin && curl https://chromium.googlesource.com/apps/libapps/+/refs/heads/main/hterm/etc/osc52.sh?format=TEXT | base64 --decode > ~/.local/bin/osc52 && chmod u+x ~/.local/bin/osc52`
if command -v osc52 &>/dev/null; then
	printf "%s" "$(cat)" | osc52
	exit 0
fi

if [ "$(uname)" = 'Darwin' ]; then
	# May work but not tested yet
	printf "%s" "$(cat)" | pbcopy
	exit 0
fi

# If Linux
if command -v xsel &>/dev/null; then
	printf "%s" "$(cat)" | xsel --clipboard --input
	exit 0
fi

echo 'No clipboard provider is installed. Quit'
exit 1
