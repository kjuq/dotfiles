[commit]
	gpgsign = true
	verbose = true

[pull]
	rebase = false
[init]
	defaultBranch = master

[credential]
	helper = cache --timeout=3600
[credential "https://github.com"]
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = !/usr/bin/gh auth git-credential

[core]
	pager = "nvim -R -c 'setlocal nonumber norelativenumber'"
	sparsecheckout = true
[color]
	pager = false

[diff]
	tool = nvimdiff
[difftool]
	prompt = false

[merge]
	tool = nvimdiff
[mergetool "nvimdiff"]
	layout = "LOCAL,BASE,REMOTE / MERGED"

[safe]
	directory = /storage/emulated/0/*

